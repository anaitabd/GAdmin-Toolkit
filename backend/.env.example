# Backend Configuration
LOG_LEVEL=info

# ============================================================================
# Database
# ============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gadmin_toolkit
DB_USER=gadmin_user
DB_PASSWORD=changeme_secure_password_here

# ============================================================================
# Redis & Job Queue
# ============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ============================================================================
# Authentication & Security
# ============================================================================
# Static API tokens (space-separated; use UUID format in production)
API_TOKENS=user-token-12345678-1234-1234-1234-123456789012 admin-token-87654321-4321-4321-4321-210987654321

# JWT secret (change this in production!)
JWT_SECRET=your_super_secret_jwt_key_change_in_production

# ============================================================================
# Job Execution
# ============================================================================
# Max concurrent jobs running at once
MAX_CONCURRENT_JOBS=10

# Default job timeout (milliseconds)
JOB_TIMEOUT_MS=300000

# Max log size per job (bytes); rest uploaded to S3/storage
MAX_LOG_SIZE_BYTES=1048576

# Temp directory for isolated job execution
TEMP_DIR_BASE=/tmp/gadmin-toolkit-jobs

# ============================================================================
# Rate Limiting
# ============================================================================
# Max requests per token per minute
RATE_LIMIT_PER_TOKEN_PER_MIN=100

# Max requests globally per second
RATE_LIMIT_GLOBAL_PER_SEC=50

# ============================================================================
# Script Whitelist
# ============================================================================
# Path to config/scripts.yml (relative to project root)
SCRIPTS_CONFIG_PATH=../config/scripts.yml

# ============================================================================
# Monitoring & Observability
# ============================================================================
# Prometheus metrics port
METRICS_PORT=9090

# ============================================================================
# Optional: Object Storage (for large logs)
# ============================================================================
# S3_BUCKET=gadmin-toolkit-logs
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# ============================================================================
# Optional: Slack/Email Notifications
# ============================================================================
# SLACK_WEBHOOK_URL=
# NOTIFICATION_EMAIL=admin@example.com

